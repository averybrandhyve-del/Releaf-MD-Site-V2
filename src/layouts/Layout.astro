---
import SEO from '../components/SEO.astro';
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<SEO title={title} description={description} />
	</head>
	<body class="flex flex-col min-h-screen">
		<!-- Top Bar (Contact Info) -->
		<div class="bg-brand-dark text-white py-2 px-4 sm:px-6 lg:px-8 text-sm flex justify-center sm:justify-end gap-6">
			<a href="tel:8136513492" class="hover:text-brand-light transition-colors flex items-center gap-1">📞 813-651-3492</a>
			<a href="mailto:info@releafmd.com" class="hover:text-brand-light transition-colors flex items-center gap-1">✉️ info@releafmd.com</a>
		</div>

		<!-- Main Header -->
		<header class="bg-white shadow-sm sticky top-0 z-50">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="flex justify-between items-center py-4">
					<!-- Logo -->
					<div class="flex-shrink-0 flex items-center">
						<a href="/" class="block">
							<img src="/logo.svg" alt="Releaf MD Logo" class="h-20 sm:h-26 w-auto" />
						</a>
					</div>
					
					<!-- Desktop Nav -->
					<nav class="hidden md:flex space-x-6 items-center">
						<!-- Services Dropdown -->
						<div class="relative group">
							<button class="text-slate-600 hover:text-brand-primary font-medium text-sm py-2 inline-flex items-center">Services <span class="ml-1 text-xs">▼</span></button>
							<div class="absolute left-0 top-full pt-2 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
								<div class="bg-white border border-slate-200 rounded-md shadow-lg py-2">
									<a href="/florida-medical-marijuana-card-guide" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-brand-primary">The Complete Guide (Pillar)</a>
									<a href="/evaluations" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-brand-primary">New Evaluations</a>
									<a href="/renewals" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-brand-primary">Renewals</a>
									<a href="/qualifying-conditions" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-brand-primary">Qualifying Conditions</a>
									<a href="/treatment-plans" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-brand-primary">Treatment Plans</a>
								</div>
							</div>
						</div>

						<!-- Locations Dropdown -->
						<div class="relative group">
							<button class="text-slate-600 hover:text-brand-primary font-medium text-sm py-2 inline-flex items-center">Locations <span class="ml-1 text-xs">▼</span></button>
							<div class="absolute left-0 top-full pt-2 w-48 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
								<div class="bg-white border border-slate-200 rounded-md shadow-lg py-2">
									<a href="/locations/brandon" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-brand-primary">Brandon, FL</a>
									<a href="/locations/riverview-valrico" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-brand-primary">Riverview & Valrico</a>
								</div>
							</div>
						</div>

						<!-- Resources Dropdown -->
						<div class="relative group">
							<button class="text-slate-600 hover:text-brand-primary font-medium text-sm py-2 inline-flex items-center">Resources <span class="ml-1 text-xs">▼</span></button>
							<div class="absolute left-0 top-full pt-2 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
								<div class="bg-white border border-slate-200 rounded-md shadow-lg py-2">
									<a href="/costs" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-brand-primary">Pricing & Costs</a>
									<a href="/seniors" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-brand-primary">Seniors Guide</a>
									<a href="/physician-referral" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-brand-primary">Physician Referrals</a>
									<a href="/schedule-3-changes" class="block px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 hover:text-brand-primary">Schedule 3 Info</a>
								</div>
							</div>
						</div>

						<a href="/#how-it-works" class="text-slate-600 hover:text-brand-primary font-medium text-sm">How It Works</a>
						<a href="/#faq" class="text-slate-600 hover:text-brand-primary font-medium text-sm">FAQ</a>
						<a href="/#lead-form" class="bg-brand-primary hover:bg-brand-dark text-white px-5 py-2 rounded-md font-bold text-sm transition-colors">
							CALL NOW
						</a>
					</nav>
				</div>
			</div>
		</header>

		<main class="flex-grow">
			<slot />
		</main>

		<!-- Footer -->
		<footer class="bg-slate-900 text-slate-300 py-16" id="footer">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
					<div class="md:col-span-2">
						<a href="/" class="inline-block mb-6 bg-white p-3 rounded-xl shadow-sm">
							<img src="/logo.svg" alt="Releaf MD Logo" class="h-16 sm:h-20 w-auto" />
						</a>
						<p class="text-sm mb-6 max-w-sm">ReleafMD is a physician-led clinic for Florida medical marijuana evaluations. We provide clinical assessments and certification guidance. We are not a dispensary and do not sell cannabis products.</p>
					</div>
					
					<div>
						<h3 class="text-white font-bold mb-4 uppercase text-sm tracking-wider">Quick Links</h3>
						<ul class="space-y-3 text-sm">
							<li><a href="/#visit-types" class="hover:text-white transition-colors">Visit Types</a></li>
							<li><a href="/#how-it-works" class="hover:text-white transition-colors">How It Works</a></li>
							<li><a href="/#doctor-feature" class="hover:text-white transition-colors">Physician</a></li>
							<li><a href="/#faq" class="hover:text-white transition-colors">FAQ</a></li>
						</ul>
					</div>

					<div>
						<h3 class="text-white font-bold mb-4 uppercase text-sm tracking-wider">Contact</h3>
						<ul class="space-y-3 text-sm">
							<li><a href="tel:8136513492" class="hover:text-white transition-colors">813-651-3492</a></li>
							<li><a href="mailto:info@releafmd.com" class="hover:text-white transition-colors">info@releafmd.com</a></li>
							<li><a href="/#lead-form" class="hover:text-white transition-colors">Schedule Appointment</a></li>
						</ul>
					</div>
				</div>
			</div>
		</footer>
	</body>
</html>
