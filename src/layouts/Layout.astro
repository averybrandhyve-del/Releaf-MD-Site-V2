---
import { ClientRouter } from 'astro:transitions';
import SEO from '../components/SEO.astro';
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<SEO title={title} description={description} />
		<ClientRouter />
	</head>
	<body class="flex flex-col min-h-screen bg-brand-mint text-slate-800 antialiased selection:bg-brand-primary selection:text-white font-sans relative">
		<!-- Scroll Progress Bar -->
		<div class="scroll-progress"></div>
		<!-- Ambient Background Blobs -->
		<div class="fixed inset-0 overflow-hidden pointer-events-none z-0">
			<div class="absolute -top-40 -left-40 w-96 h-96 rounded-full bg-brand-primary/5 blur-3xl animate-drift-blob"></div>
			<div class="absolute top-1/2 -right-40 w-80 h-80 rounded-full bg-brand-accent/5 blur-3xl animate-drift-blob" style="animation-delay: -4s;"></div>
		</div>
		<!-- Top Bar (Contact Info) -->
		<div class="bg-brand-dark text-white py-2 px-4 sm:px-6 lg:px-8 text-sm flex justify-center sm:justify-end gap-6 border-b border-brand-primary/10">
			<a href="tel:8136513492" class="hover:text-brand-accent transition-colors flex items-center gap-1 active-press">📞 813-651-3492</a>
			<a href="mailto:info@releafmd.com" class="hover:text-brand-accent transition-colors flex items-center gap-1 active-press">✉️ info@releafmd.com</a>
		</div>

		<!-- Main Header -->
		<header class="bg-white sticky top-0 z-50 shadow-whisper">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="flex justify-between items-center py-3">
					<!-- Logo -->
					<div class="flex-shrink-0 flex items-center">
						<a href="/" class="block active-press">
							<img src="/logo.svg" alt="Releaf MD Logo" class="h-16 sm:h-20 w-auto" />
						</a>
					</div>
					
					<!-- Desktop Nav -->
					<nav class="hidden md:flex space-x-6 items-center">
						<!-- Services Dropdown -->
						<div class="relative group">
							<button class="text-slate-600 hover:text-brand-primary font-bold text-sm py-2 inline-flex items-center gap-1 cursor-pointer nav-link-underline">
								Services <span class="text-xs transition-transform group-hover:rotate-180">▼</span>
							</button>
							<div class="absolute left-0 top-full pt-2 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
								<div class="bg-white border border-slate-100 rounded-xl shadow-whisper py-2">
									<a href="/florida-medical-marijuana-card-guide" class="block px-4 py-2 text-sm text-slate-600 hover:bg-brand-mint hover:text-brand-primary transition-colors">The Complete Guide</a>
									<a href="/evaluations" class="block px-4 py-2 text-sm text-slate-600 hover:bg-brand-mint hover:text-brand-primary transition-colors">New Evaluations</a>
									<a href="/renewals" class="block px-4 py-2 text-sm text-slate-600 hover:bg-brand-mint hover:text-brand-primary transition-colors">Renewals</a>
									<a href="/qualifying-conditions" class="block px-4 py-2 text-sm text-slate-600 hover:bg-brand-mint hover:text-brand-primary transition-colors">Qualifying Conditions</a>
									<a href="/treatment-plans" class="block px-4 py-2 text-sm text-slate-600 hover:bg-brand-mint hover:text-brand-primary transition-colors">Treatment Plans</a>
									<a href="/cbd-iv-infusions" class="block px-4 py-2 text-sm text-slate-600 hover:bg-brand-mint hover:text-brand-primary transition-colors">CBD IV Infusions</a>
									<a href="/pediatric-cbd" class="block px-4 py-2 text-sm text-slate-600 hover:bg-brand-mint hover:text-brand-primary transition-colors">Pediatric CBD</a>
								</div>
							</div>
						</div>

						<!-- Locations Dropdown -->
						<div class="relative group">
							<button class="text-slate-600 hover:text-brand-primary font-bold text-sm py-2 inline-flex items-center gap-1 cursor-pointer nav-link-underline">
								Locations <span class="text-xs transition-transform group-hover:rotate-180">▼</span>
							</button>
							<div class="absolute left-0 top-full pt-2 w-48 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
								<div class="bg-white border border-slate-100 rounded-xl shadow-whisper py-2">
									<a href="/locations/brandon" class="block px-4 py-2 text-sm text-slate-600 hover:bg-brand-mint hover:text-brand-primary transition-colors">Brandon, FL</a>
									<a href="/locations/riverview-valrico" class="block px-4 py-2 text-sm text-slate-600 hover:bg-brand-mint hover:text-brand-primary transition-colors">Riverview & Valrico</a>
								</div>
							</div>
						</div>

						<!-- Resources Dropdown -->
						<div class="relative group">
							<button class="text-slate-600 hover:text-brand-primary font-bold text-sm py-2 inline-flex items-center gap-1 cursor-pointer nav-link-underline">
								Resources <span class="text-xs transition-transform group-hover:rotate-180">▼</span>
							</button>
							<div class="absolute left-0 top-full pt-2 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
								<div class="bg-white border border-slate-100 rounded-xl shadow-whisper py-2">
									<a href="/costs" class="block px-4 py-2 text-sm text-slate-600 hover:bg-brand-mint hover:text-brand-primary transition-colors">Pricing & Costs</a>
									<a href="/seniors" class="block px-4 py-2 text-sm text-slate-600 hover:bg-brand-mint hover:text-brand-primary transition-colors">Seniors Guide</a>
									<a href="/physician-referral" class="block px-4 py-2 text-sm text-slate-600 hover:bg-brand-mint hover:text-brand-primary transition-colors">Physician Referrals</a>
									<a href="/schedule-3-changes" class="block px-4 py-2 text-sm text-slate-600 hover:bg-brand-mint hover:text-brand-primary transition-colors">Schedule 3 Info</a>
								</div>
							</div>
						</div>

					<a href="/how-it-works" class="text-slate-600 hover:text-brand-primary font-bold text-sm transition-colors nav-link-underline">How It Works</a>
						<a href="/#faq" class="text-slate-600 hover:text-brand-primary font-bold text-sm transition-colors nav-link-underline">FAQ</a>
						<a target="_blank" rel="noopener noreferrer" href="https://live.vcita.com/site/DrKellyKing/online-scheduling" class="bg-brand-accent hover:bg-brand-dark text-white px-6 py-2.5 rounded-full font-bold text-sm tracking-wide transition-all shadow-whisper active-press">
							BOOK ONLINE
						</a>
					</nav>

					<!-- Mobile Nav Toggle -->
					<button id="mobile-menu-btn" class="md:hidden p-2 text-slate-600 hover:text-brand-primary active-press" aria-label="Toggle menu">
						<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16" />
						</svg>
					</button>
				</div>
			</div>

			<!-- Mobile Menu Dropdown -->
			<div id="mobile-menu" class="hidden border-t border-slate-100 bg-white px-4 py-4 space-y-3 md:hidden shadow-lg">
				<div class="font-bold text-slate-400 text-xs tracking-wider uppercase mb-1">Services</div>
				<div class="grid grid-cols-2 gap-2 pl-2">
					<a href="/florida-medical-marijuana-card-guide" class="text-sm text-slate-700 hover:text-brand-primary py-1">Complete Guide</a>
					<a href="/evaluations" class="text-sm text-slate-700 hover:text-brand-primary py-1">New Evaluations</a>
					<a href="/renewals" class="text-sm text-slate-700 hover:text-brand-primary py-1">Renewals</a>
					<a href="/qualifying-conditions" class="text-sm text-slate-700 hover:text-brand-primary py-1">Conditions</a>
					<a href="/treatment-plans" class="text-sm text-slate-700 hover:text-brand-primary py-1">Treatment Plans</a>
					<a href="/cbd-iv-infusions" class="text-sm text-slate-700 hover:text-brand-primary py-1">CBD IV Infusions</a>
					<a href="/pediatric-cbd" class="text-sm text-slate-700 hover:text-brand-primary py-1">Pediatric CBD</a>
				</div>
				<div class="h-px bg-slate-100 my-2"></div>
				<div class="font-bold text-slate-400 text-xs tracking-wider uppercase mb-1">Locations & Resources</div>
				<div class="grid grid-cols-2 gap-2 pl-2">
					<a href="/locations/brandon" class="text-sm text-slate-700 hover:text-brand-primary py-1">Brandon, FL</a>
					<a href="/locations/riverview-valrico" class="text-sm text-slate-700 hover:text-brand-primary py-1">Riverview/Valrico</a>
					<a href="/costs" class="text-sm text-slate-700 hover:text-brand-primary py-1">Pricing & Costs</a>
					<a href="/seniors" class="text-sm text-slate-700 hover:text-brand-primary py-1">Seniors Guide</a>
					<a href="/physician-referral" class="text-sm text-slate-700 hover:text-brand-primary py-1">Referrals</a>
					<a href="/schedule-3-changes" class="text-sm text-slate-700 hover:text-brand-primary py-1">Schedule 3</a>
					<a href="/#faq" class="text-sm text-slate-700 hover:text-brand-primary py-1">FAQ</a>
				</div>
				<div class="h-px bg-slate-100 my-2"></div>
				<div class="flex flex-col gap-3 pt-2">
					<a href="/how-it-works" class="text-center font-bold text-slate-700 hover:text-brand-primary py-2 bg-slate-50 rounded-lg">How It Works</a>
					<a target="_blank" rel="noopener noreferrer" href="https://live.vcita.com/site/DrKellyKing/online-scheduling" class="bg-brand-accent hover:bg-brand-primary text-white text-center py-3 rounded-full font-bold text-sm tracking-wider shadow-md">
						BOOK ONLINE
					</a>
				</div>
			</div>
		</header>

		<script data-astro-rerun>
			const btn = document.getElementById('mobile-menu-btn');
			const menu = document.getElementById('mobile-menu');
			if (btn && menu) {
				btn.addEventListener('click', () => {
					menu.classList.toggle('hidden');
				});
			}
		</script>

		<main class="flex-grow">
			<slot />
		</main>

		<!-- Footer -->
		<footer class="bg-brand-dark text-slate-200 py-16 border-t-4 border-brand-accent" id="footer">
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
					<div>
						<a href="/" class="inline-block mb-4 bg-white p-2 rounded-xl shadow-whisper active-press">
							<img src="/logo.svg" alt="Releaf MD Logo" class="h-12 w-auto" />
						</a>
						<p class="text-xs text-slate-300 max-w-sm font-sans leading-relaxed">
							ReleafMD is a compassionate, physician-led clinic for Florida medical marijuana evaluations. We are not a dispensary.
						</p>
					</div>
					
					<div>
						<h3 class="text-brand-accent font-serif-headline text-sm font-bold mb-4 uppercase tracking-wider">Quick Links</h3>
						<ul class="space-y-2 text-xs">
							<li><a href="/#visit-types" class="text-slate-300 hover:text-white transition-colors font-semibold">Visit Types</a></li>
							<li><a href="/how-it-works" class="text-slate-300 hover:text-white transition-colors font-semibold">How It Works</a></li>
							<li><a href="/#doctor-feature" class="text-slate-300 hover:text-white transition-colors font-semibold">Our Physician</a></li>
							<li><a href="/#faq" class="text-slate-300 hover:text-white transition-colors font-semibold">FAQs</a></li>
						</ul>
					</div>

					<div>
						<h3 class="text-brand-accent font-serif-headline text-sm font-bold mb-4 uppercase tracking-wider">Contact</h3>
						<ul class="space-y-2 text-xs">
							<li><a href="tel:8136513492" class="text-slate-300 hover:text-white font-bold transition-colors">📞 813-651-3492</a></li>
							<li><a href="mailto:info@releafmd.com" class="text-slate-300 hover:text-white font-bold transition-colors">✉️ info@releafmd.com</a></li>
							<li><a target="_blank" rel="noopener noreferrer" href="https://live.vcita.com/site/DrKellyKing/online-scheduling" class="inline-block mt-2 bg-brand-primary text-white px-4 py-2 rounded-full font-bold text-[10px] hover:bg-brand-accent transition-colors shadow-md active-press">Book Appointment</a></li>
							<li class="flex items-center gap-3 mt-3 pt-2 border-t border-brand-primary/10">
								<a href="http://www.facebook.com/releafmdflorida" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors" aria-label="Facebook">
									<svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z"/></svg>
								</a>
								<a href="http://www.twitter.com/releafmd" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white transition-colors" aria-label="Twitter">
									<svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
								</a>
							</li>
						</ul>
					</div>

					<div>
						<h3 class="text-brand-accent font-serif-headline text-sm font-bold mb-4 uppercase tracking-wider">Clinic Hours & Info</h3>
						<p class="text-xs text-slate-300 font-semibold mb-1">
							📍 935 Oakfield Dr.<br/>Brandon, FL 33511
						</p>
						<p class="text-[11px] text-slate-400 leading-relaxed mt-2">
							<strong>Mon &ndash; Fri:</strong> 9 AM &ndash; 4 PM<br/>
							<strong>Sat &ndash; Sun:</strong> Closed<br/>
							<a href="https://maps.google.com/?q=935+Oakfield+Dr+Brandon+FL+33511" target="_blank" rel="noopener noreferrer" class="text-brand-accent font-bold hover:underline block mt-1">Get Directions &rarr;</a>
						</p>
					</div>
				</div>
				<div class="border-t border-brand-primary/20 mt-12 pt-8 text-center text-xs text-slate-400">
					<p>&copy; {new Date().getFullYear()} Releaf MD. All rights reserved. Dr. Kelly Ennix King, Certified Certifying Physician.</p>
				</div>
			</div>
		</footer>

		<!-- Floating Call/Book Button (Signature CTA Concept) -->
		<a href="tel:8136513492" class="fixed bottom-6 right-6 z-50 flex items-center justify-center w-14 h-14 bg-brand-accent hover:bg-brand-primary text-white rounded-full shadow-leaf active-press transition-all group" aria-label="Call Releaf MD Now">
			<svg class="w-6 h-6 animate-pulse group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
			</svg>
			<span class="absolute right-16 bg-brand-dark text-white text-xs font-bold py-2 px-3 rounded-lg opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity duration-200 shadow-md whitespace-nowrap">
				Call 813-651-3492
			</span>
		</a>
	</body>
</html>
