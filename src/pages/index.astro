---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="ReleafMD | Florida Medical Marijuana Card Evaluations" 
  description="Clear, private, physician-led evaluations for new patients, renewals, and transfers in Florida. compassionate care from Dr. Kelly Ennix King."
>

  <!-- Hero Section (Cream/Mint Canvas) -->
  <section class="relative bg-brand-mint py-16 sm:py-24 lg:py-32 overflow-hidden border-b border-brand-primary/10">
    <!-- Top Vine Border -->
    <div class="absolute top-0 left-0 w-full h-6 pointer-events-none z-20">
      <!-- Horizontal stem line -->
      <div class="absolute top-2 left-0 right-0 h-[2px] bg-brand-primary/30 animate-grow-horizontal-stem"></div>
      <!-- Leaves -->
      <div class="absolute top-[2px] left-[10%] -translate-x-1/2">
        <div class="animate-grow-horizontal-leaf" style="animation-delay: 0.3s;">
          <svg class="w-3.5 h-3.5 text-brand-primary/80 rotate-135" viewBox="0 0 10 10">
            <path d="M0,10 C3,5 8,5 5,0 C2,0 -3,5 0,10" fill="currentColor"/>
          </svg>
        </div>
      </div>
      <div class="absolute top-[2px] left-[20%] -translate-x-1/2">
        <div class="animate-grow-horizontal-leaf" style="animation-delay: 0.6s;">
          <svg class="w-3.5 h-3.5 text-brand-primary/80 rotate-225" viewBox="0 0 10 10">
            <path d="M0,10 C3,5 8,5 5,0 C2,0 -3,5 0,10" fill="currentColor"/>
          </svg>
        </div>
      </div>
      <div class="absolute top-[2px] left-[30%] -translate-x-1/2">
        <div class="animate-grow-horizontal-leaf" style="animation-delay: 0.9s;">
          <svg class="w-3.5 h-3.5 text-brand-primary/80 rotate-135" viewBox="0 0 10 10">
            <path d="M0,10 C3,5 8,5 5,0 C2,0 -3,5 0,10" fill="currentColor"/>
          </svg>
        </div>
      </div>
      <div class="absolute top-[2px] left-[40%] -translate-x-1/2">
        <div class="animate-grow-horizontal-leaf" style="animation-delay: 1.2s;">
          <svg class="w-3.5 h-3.5 text-brand-primary/80 rotate-225" viewBox="0 0 10 10">
            <path d="M0,10 C3,5 8,5 5,0 C2,0 -3,5 0,10" fill="currentColor"/>
          </svg>
        </div>
      </div>
      <div class="absolute top-[2px] left-[50%] -translate-x-1/2">
        <div class="animate-grow-horizontal-leaf" style="animation-delay: 1.5s;">
          <svg class="w-3.5 h-3.5 text-brand-primary/80 rotate-135" viewBox="0 0 10 10">
            <path d="M0,10 C3,5 8,5 5,0 C2,0 -3,5 0,10" fill="currentColor"/>
          </svg>
        </div>
      </div>
      <div class="absolute top-[2px] left-[60%] -translate-x-1/2">
        <div class="animate-grow-horizontal-leaf" style="animation-delay: 1.8s;">
          <svg class="w-3.5 h-3.5 text-brand-primary/80 rotate-225" viewBox="0 0 10 10">
            <path d="M0,10 C3,5 8,5 5,0 C2,0 -3,5 0,10" fill="currentColor"/>
          </svg>
        </div>
      </div>
      <div class="absolute top-[2px] left-[70%] -translate-x-1/2">
        <div class="animate-grow-horizontal-leaf" style="animation-delay: 2.1s;">
          <svg class="w-3.5 h-3.5 text-brand-primary/80 rotate-135" viewBox="0 0 10 10">
            <path d="M0,10 C3,5 8,5 5,0 C2,0 -3,5 0,10" fill="currentColor"/>
          </svg>
        </div>
      </div>
      <div class="absolute top-[2px] left-[80%] -translate-x-1/2">
        <div class="animate-grow-horizontal-leaf" style="animation-delay: 2.4s;">
          <svg class="w-3.5 h-3.5 text-brand-primary/80 rotate-225" viewBox="0 0 10 10">
            <path d="M0,10 C3,5 8,5 5,0 C2,0 -3,5 0,10" fill="currentColor"/>
          </svg>
        </div>
      </div>
      <div class="absolute top-[2px] left-[90%] -translate-x-1/2">
        <div class="animate-grow-horizontal-leaf" style="animation-delay: 2.7s;">
          <svg class="w-3.5 h-3.5 text-brand-primary/80 rotate-135" viewBox="0 0 10 10">
            <path d="M0,10 C3,5 8,5 5,0 C2,0 -3,5 0,10" fill="currentColor"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Bottom Vine Border -->
    <div class="absolute bottom-0 left-0 w-full h-6 pointer-events-none z-20">
      <!-- Horizontal stem line -->
      <div class="absolute bottom-2 left-0 right-0 h-[2px] bg-brand-primary/30 animate-grow-horizontal-stem"></div>
      <!-- Leaves -->
      <div class="absolute bottom-[2px] left-[10%] -translate-x-1/2">
        <div class="animate-grow-horizontal-leaf" style="animation-delay: 0.3s;">
          <svg class="w-3.5 h-3.5 text-brand-primary/80 rotate-45" viewBox="0 0 10 10">
            <path d="M0,10 C3,5 8,5 5,0 C2,0 -3,5 0,10" fill="currentColor"/>
          </svg>
        </div>
      </div>
      <div class="absolute bottom-[2px] left-[20%] -translate-x-1/2">
        <div class="animate-grow-horizontal-leaf" style="animation-delay: 0.6s;">
          <svg class="w-3.5 h-3.5 text-brand-primary/80 rotate-315" viewBox="0 0 10 10">
            <path d="M0,10 C3,5 8,5 5,0 C2,0 -3,5 0,10" fill="currentColor"/>
          </svg>
        </div>
      </div>
      <div class="absolute bottom-[2px] left-[30%] -translate-x-1/2">
        <div class="animate-grow-horizontal-leaf" style="animation-delay: 0.9s;">
          <svg class="w-3.5 h-3.5 text-brand-primary/80 rotate-45" viewBox="0 0 10 10">
            <path d="M0,10 C3,5 8,5 5,0 C2,0 -3,5 0,10" fill="currentColor"/>
          </svg>
        </div>
      </div>
      <div class="absolute bottom-[2px] left-[40%] -translate-x-1/2">
        <div class="animate-grow-horizontal-leaf" style="animation-delay: 1.2s;">
          <svg class="w-3.5 h-3.5 text-brand-primary/80 rotate-315" viewBox="0 0 10 10">
            <path d="M0,10 C3,5 8,5 5,0 C2,0 -3,5 0,10" fill="currentColor"/>
          </svg>
        </div>
      </div>
      <div class="absolute bottom-[2px] left-[50%] -translate-x-1/2">
        <div class="animate-grow-horizontal-leaf" style="animation-delay: 1.5s;">
          <svg class="w-3.5 h-3.5 text-brand-primary/80 rotate-45" viewBox="0 0 10 10">
            <path d="M0,10 C3,5 8,5 5,0 C2,0 -3,5 0,10" fill="currentColor"/>
          </svg>
        </div>
      </div>
      <div class="absolute bottom-[2px] left-[60%] -translate-x-1/2">
        <div class="animate-grow-horizontal-leaf" style="animation-delay: 1.8s;">
          <svg class="w-3.5 h-3.5 text-brand-primary/80 rotate-315" viewBox="0 0 10 10">
            <path d="M0,10 C3,5 8,5 5,0 C2,0 -3,5 0,10" fill="currentColor"/>
          </svg>
        </div>
      </div>
      <div class="absolute bottom-[2px] left-[70%] -translate-x-1/2">
        <div class="animate-grow-horizontal-leaf" style="animation-delay: 2.1s;">
          <svg class="w-3.5 h-3.5 text-brand-primary/80 rotate-45" viewBox="0 0 10 10">
            <path d="M0,10 C3,5 8,5 5,0 C2,0 -3,5 0,10" fill="currentColor"/>
          </svg>
        </div>
      </div>
      <div class="absolute bottom-[2px] left-[80%] -translate-x-1/2">
        <div class="animate-grow-horizontal-leaf" style="animation-delay: 2.4s;">
          <svg class="w-3.5 h-3.5 text-brand-primary/80 rotate-315" viewBox="0 0 10 10">
            <path d="M0,10 C3,5 8,5 5,0 C2,0 -3,5 0,10" fill="currentColor"/>
          </svg>
        </div>
      </div>
      <div class="absolute bottom-[2px] left-[90%] -translate-x-1/2">
        <div class="animate-grow-horizontal-leaf" style="animation-delay: 2.7s;">
          <svg class="w-3.5 h-3.5 text-brand-primary/80 rotate-45" viewBox="0 0 10 10">
            <path d="M0,10 C3,5 8,5 5,0 C2,0 -3,5 0,10" fill="currentColor"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Localized Hero Blobs -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
      <div class="absolute top-10 left-10 w-72 h-72 rounded-full bg-brand-primary/10 blur-3xl animate-drift-blob"></div>
      <div class="absolute bottom-10 right-10 w-80 h-80 rounded-full bg-brand-accent/10 blur-3xl animate-drift-blob" style="animation-delay: -6s;"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Text content (60%) -->
        <div class="lg:col-span-7 space-y-6 text-left">
          <div class="inline-flex items-center gap-2 px-3 py-1 bg-brand-primary/10 text-brand-primary rounded-full text-xs font-bold uppercase tracking-wider">
            🌿 Compassionate Florida Care Since 2018
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-serif-headline text-brand-dark tracking-tight leading-tight">
            Clear, private, <br/>
            <span class="text-brand-primary">physician-led</span> evaluations.
          </h1>
          <p class="text-lg sm:text-xl text-slate-600 max-w-2xl font-sans leading-relaxed">
            Get certified for your Florida Medical Marijuana Card with Dr. Kelly Ennix King. Simple, secure, and fully guided process for new patients, renewals, and doctor transfers.
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4 pt-4">
            <a href="https://live.vcita.com/site/DrKellyKing/online-scheduling?service=xnfeicu6jent0179" class="w-full sm:w-auto bg-brand-accent hover:bg-brand-dark text-white px-8 py-4 rounded-full font-bold text-base tracking-wide transition-all shadow-md active-press text-center">
              SCHEDULE APPOINTMENT
            </a>
            <a href="tel:8136513492" class="w-full sm:w-auto bg-white hover:bg-brand-mint text-brand-dark border-2 border-brand-primary/20 px-8 py-4 rounded-full font-bold text-base tracking-wide transition-all active-press text-center shadow-whisper">
              CALL 813-651-3492
            </a>
          </div>
        </div>

        <!-- Hero Decorative Graphic (40%) -->
        <div class="lg:col-span-5 flex justify-center relative">
          <!-- Pulsing Ring behind the spinning main block -->
          <div class="absolute w-76 sm:w-84 h-76 sm:h-84 bg-brand-primary/10 rounded-full blur-sm animate-ripple z-0"></div>
          <div class="relative w-72 sm:w-80 h-72 sm:h-80 bg-brand-primary/20 rounded-full flex items-center justify-center border-4 border-brand-white shadow-whisper animate-rock z-10">
            <div class="absolute inset-4 bg-brand-dark/10 rounded-full flex items-center justify-center animate-counter-rock">
              <div class="w-48 h-48 bg-brand-primary rounded-full flex flex-col items-center justify-center text-white text-center p-6 shadow-md">
                <span class="text-4xl mb-1">📋</span>
                <span class="font-serif-headline font-bold text-sm tracking-wide">RELEAF MD</span>
                <span class="text-xs text-brand-mint mt-1">100% Risk-Free Certification</span>
              </div>
            </div>
            <!-- Floating badge -->
            <div class="absolute -top-4 -right-4 bg-brand-accent text-white font-bold text-xs py-2 px-3 rounded-full shadow-md animate-float">
              <span class="inline-block animate-counter-rock">Veteran-Led 🇺🇸</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Visit Types Section (White Canvas with Rounded Cards) -->
  <section id="visit-types" class="py-20 bg-white reveal-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-16 text-center max-w-3xl mx-auto">
        <h2 class="text-3xl font-serif-headline text-brand-dark mb-4">UNDERSTAND VISIT TYPES</h2>
        <div class="h-1 w-20 bg-brand-accent mx-auto mb-6 rounded-full"></div>
        <p class="text-lg text-slate-600">
          Florida medical marijuana requirements vary depending on your certification cycle status. Choose your path below to get started correctly.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- New Patient -->
        <div class="bg-brand-mint/40 p-8 rounded-2xl border border-brand-primary/10 shadow-whisper hover-lift flex flex-col justify-between">
          <div>
            <span class="text-3xl">🌱</span>
            <h3 class="text-xl font-serif-headline font-bold mt-4 mb-3 text-brand-dark uppercase">NEW PATIENT</h3>
            <p class="text-slate-600 text-sm leading-relaxed mb-6">
              For first-time certification in Florida. State law requires an in-person physical exam. We review your medical history, confirm your qualifying condition, and register you in the Medical Marijuana Use Registry.
            </p>
          </div>
          <a href="/evaluations" class="bg-brand-primary hover:bg-brand-dark text-white text-center py-2.5 rounded-full font-bold text-sm transition-colors active-press shadow-sm mt-4">
            NEW PATIENT INFO &rarr;
          </a>
        </div>

        <!-- Renewal -->
        <div class="bg-brand-mint/40 p-8 rounded-2xl border border-brand-primary/10 shadow-whisper hover-lift flex flex-col justify-between">
          <div>
            <span class="text-3xl">🔄</span>
            <h3 class="text-xl font-serif-headline font-bold mt-4 mb-3 text-brand-dark uppercase">RENEWAL</h3>
            <p class="text-slate-600 text-sm leading-relaxed mb-6">
              Florida requires an evaluation follow-up at least every 30 weeks (210 days). For established patients, renewal follow-ups can be completed via telehealth or in-person. Check if you are ready to book your renewal!
            </p>
          </div>
          <a href="/renewals" class="bg-brand-accent hover:bg-brand-dark text-white text-center py-2.5 rounded-full font-bold text-sm transition-colors active-press shadow-sm mt-4">
            BOOK RENEWAL &rarr;
          </a>
        </div>

        <!-- Transfer -->
        <div class="bg-brand-mint/40 p-8 rounded-2xl border border-brand-primary/10 shadow-whisper hover-lift flex flex-col justify-between">
          <div>
            <span class="text-3xl">🤝</span>
            <h3 class="text-xl font-serif-headline font-bold mt-4 mb-3 text-brand-dark uppercase">TRANSFER</h3>
            <p class="text-slate-600 text-sm leading-relaxed mb-6">
              Switching from another doctor to ReleafMD is seamless. We coordinate the timeline to cancel old orders in the Florida registry, avoiding duplicate fees and ensuring your medicine orders stay active.
            </p>
          </div>
          <a href="https://live.vcita.com/site/DrKellyKing/online-scheduling?service=fo0js3iwqegdlams" class="bg-brand-dark hover:bg-brand-primary text-white text-center py-2.5 rounded-full font-bold text-sm transition-colors active-press shadow-sm mt-4">
            TRANSFER TO US
          </a>
        </div>
      </div>
    </div>
  </section>



  <!-- How It Works Section (Espresso-dark Feature Band) -->
  <section id="how-it-works" class="py-20 bg-brand-dark text-white relative">
    <div class="absolute inset-0 bg-[radial-gradient(#1D8C64_1px,transparent_1px)] [background-size:16px_16px] opacity-10"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="mb-16 text-center">
        <h2 class="text-3xl font-serif-headline text-brand-mint uppercase tracking-tight mb-4">HOW IT WORKS</h2>
        <p class="text-lg text-slate-300 max-w-2xl mx-auto">
          Four straightforward steps to certified relief. Clean and simple.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative">
        <!-- Connecting Line for desktop -->
        <div class="hidden md:block absolute top-6 left-6 right-6 h-0.5 bg-brand-primary/30 z-0"></div>
        
        <div class="relative z-10 bg-brand-dark/50 p-6 rounded-xl border border-brand-primary/20 hover-lift">
          <div class="w-12 h-12 bg-brand-accent rounded-full flex items-center justify-center font-bold text-xl mb-6 shadow-md text-white">1</div>
          <h3 class="text-lg font-serif-headline font-bold mb-3 uppercase text-brand-mint">Schedule</h3>
          <p class="text-xs text-slate-300 leading-relaxed">Book online or call. We will confirm your appointment and provide intake paperwork.</p>
        </div>

        <div class="relative z-10 bg-brand-dark/50 p-6 rounded-xl border border-brand-primary/20 hover-lift">
          <div class="w-12 h-12 bg-brand-accent rounded-full flex items-center justify-center font-bold text-xl mb-6 shadow-md text-white">2</div>
          <h3 class="text-lg font-serif-headline font-bold mb-3 uppercase text-brand-mint">Consult</h3>
          <p class="text-xs text-slate-300 leading-relaxed">Meet Dr. Kelly Ennix King for a private, stress-free clinical assessment of your needs.</p>
        </div>

        <div class="relative z-10 bg-brand-dark/50 p-6 rounded-xl border border-brand-primary/20 hover-lift">
          <div class="w-12 h-12 bg-brand-accent rounded-full flex items-center justify-center font-bold text-xl mb-6 shadow-md text-white">3</div>
          <h3 class="text-lg font-serif-headline font-bold mb-3 uppercase text-brand-mint">Submit</h3>
          <p class="text-xs text-slate-300 leading-relaxed">We enter your details into the Registry. Our team assists you with the state portal tasks.</p>
        </div>

        <div class="relative z-10 bg-brand-dark/50 p-6 rounded-xl border border-brand-primary/20 hover-lift">
          <div class="w-12 h-12 bg-brand-accent rounded-full flex items-center justify-center font-bold text-xl mb-6 shadow-md text-white">4</div>
          <h3 class="text-lg font-serif-headline font-bold mb-3 uppercase text-brand-mint">Certified</h3>
          <p class="text-xs text-slate-300 leading-relaxed">Once the state approves your email ID, you can buy medicine immediately. Card arrives via mail.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Doctor Feature Section (White Canvas) -->
  <section id="doctor-feature" class="py-20 bg-white reveal-on-scroll">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row gap-12 items-center">
        <!-- Image Crate (40%) -->
        <div class="w-full lg:w-5/12">
          <div class="relative aspect-[4/5] rounded-2xl overflow-hidden shadow-whisper group hover-lift border border-brand-primary/10">
            <img src="/dr-kelly-king.jpg" alt="Dr. Kelly Ennix King" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/95 via-brand-dark/30 to-transparent flex flex-col justify-end p-6 text-left">
              <h4 class="font-serif-headline font-bold text-white text-2xl">Dr. Kelly Ennix King</h4>
              <p class="text-xs text-brand-accent font-bold mt-1 uppercase tracking-wider">Certifying Physician</p>
              <div class="mt-4 flex gap-2 flex-wrap">
                <span class="bg-brand-primary/80 backdrop-blur-sm text-white text-[10px] font-bold px-2.5 py-1 rounded-full">Air Force Veteran 🇺🇸</span>
                <span class="bg-brand-accent/80 backdrop-blur-sm text-white text-[10px] font-bold px-2.5 py-1 rounded-full">Co-Founder</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Description Crate (60%) -->
        <div class="w-full lg:w-7/12 space-y-6">
          <h2 class="text-3xl font-serif-headline text-brand-dark uppercase">MEET YOUR PHYSICIAN</h2>
          <div class="h-1 w-16 bg-brand-accent rounded-full"></div>
          <div class="space-y-4 text-slate-600 leading-relaxed text-sm">
            <p>
              Dr. Kelly Ennix King is a compassionate physician dedicated to helping patients navigate the Florida medical marijuana card system with complete confidence. Since 2018, she has focused on expanding patient access to medical cannabis through personalized treatment strategies, thorough education, and one-on-one evaluations.
            </p>
            <p>
              As a disabled Air Force veteran, Dr. Kelly understands firsthand the complexities of managing chronic pain, PTSD, and complex health conditions. At ReleafMD, she provides a safe, welcoming, and non-judgmental atmosphere. You are never treated like a number; every evaluation is detailed, personalized, and patient-first.
            </p>
            <blockquote class="border-l-4 border-brand-primary pl-4 py-1 italic text-slate-600 text-sm">
              "Providing supportive, compassionate evaluations to help you achieve holistic health and wellness with medical cannabis."
            </blockquote>
          </div>

          <div class="grid grid-cols-2 gap-4 pt-4">
            <div class="bg-brand-mint/30 p-4 rounded-xl border border-brand-primary/10 hover-lift">
              <h4 class="font-bold text-brand-dark text-sm">Trusted Quality</h4>
              <p class="text-slate-500 text-xs mt-1">Direct physician consultations with no rushed appointments.</p>
            </div>
            <div class="bg-brand-mint/30 p-4 rounded-xl border border-brand-primary/10 hover-lift">
              <h4 class="font-bold text-brand-dark text-sm">Straightforward Costs</h4>
              <p class="text-slate-500 text-xs mt-1">Clear consultation fees, zero hidden card processing fees.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive Accordion FAQ Section (White/Mint Canvas) -->
  <section id="faq" class="py-20 bg-brand-mint/50 border-t border-brand-primary/10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <h2 class="text-3xl font-serif-headline text-brand-dark uppercase">Frequently Asked Questions</h2>
        <p class="text-slate-500 mt-2">Get answers to the most common queries regarding evaluations and cards.</p>
      </div>

      <div class="space-y-4">
        <!-- FAQ 1 -->
        <div class="bg-white rounded-xl border border-brand-primary/10 shadow-whisper overflow-hidden transition-all duration-300 hover-lift">
          <button class="faq-toggle w-full px-6 py-4 flex justify-between items-center text-left focus:outline-none" data-faq="faq1">
            <span class="font-bold text-slate-800 text-sm">Are you a dispensary? Do you sell cannabis?</span>
            <span class="faq-icon text-brand-primary font-bold text-sm transition-transform duration-300">＋</span>
          </button>
          <div id="faq1" class="faq-answer faq-answer-container">
            <div class="faq-answer-content px-6 pb-5 text-xs text-slate-600 leading-relaxed border-t border-slate-50 pt-3">
              No. ReleafMD is a clinical physician evaluation center. We evaluate patients, certify qualifying conditions, and register you in the Florida Medical Marijuana Use Registry. Cannabis products must be purchased separately from licensed medical marijuana dispensaries (MMTCs).
            </div>
          </div>
        </div>

        <!-- FAQ 2 -->
        <div class="bg-white rounded-xl border border-brand-primary/10 shadow-whisper overflow-hidden transition-all duration-300 hover-lift">
          <button class="faq-toggle w-full px-6 py-4 flex justify-between items-center text-left focus:outline-none" data-faq="faq2">
            <span class="font-bold text-slate-800 text-sm">How do I book an evaluation?</span>
            <span class="faq-icon text-brand-primary font-bold text-sm transition-transform duration-300">＋</span>
          </button>
          <div id="faq2" class="faq-answer faq-answer-container">
            <div class="faq-answer-content px-6 pb-5 text-xs text-slate-600 leading-relaxed border-t border-slate-50 pt-3">
              Booking is simple! Fill out our callback request form below or call us directly at 813-651-3492. Our intake coordinator will review your information, schedule your appointment with Dr. Kelly Ennix King, and guide you through required clinical forms.
            </div>
          </div>
        </div>

        <!-- FAQ 3 -->
        <div class="bg-white rounded-xl border border-brand-primary/10 shadow-whisper overflow-hidden transition-all duration-300 hover-lift">
          <button class="faq-toggle w-full px-6 py-4 flex justify-between items-center text-left focus:outline-none" data-faq="faq3">
            <span class="font-bold text-slate-800 text-sm">What conditions qualify in Florida?</span>
            <span class="faq-icon text-brand-primary font-bold text-sm transition-transform duration-300">＋</span>
          </button>
          <div id="faq3" class="faq-answer faq-answer-container">
            <div class="faq-answer-content px-6 pb-5 text-xs text-slate-600 leading-relaxed border-t border-slate-50 pt-3">
              Florida law specifies several qualifying conditions, including cancer, epilepsy, glaucoma, HIV/AIDS, PTSD, ALS, Crohn's, Parkinson's, Multiple Sclerosis, and chronic nonmalignant pain. Additionally, physicians have the discretion to certify other conditions of similar severity or symptom profile.
            </div>
          </div>
        </div>

        <!-- FAQ 4 -->
        <div class="bg-white rounded-xl border border-brand-primary/10 shadow-whisper overflow-hidden transition-all duration-300 hover-lift">
          <button class="faq-toggle w-full px-6 py-4 flex justify-between items-center text-left focus:outline-none" data-faq="faq4">
            <span class="font-bold text-slate-800 text-sm">Can I renew early? When is my renewal window?</span>
            <span class="faq-icon text-brand-primary font-bold text-sm transition-transform duration-300">＋</span>
          </button>
          <div id="faq4" class="faq-answer faq-answer-container">
            <div class="faq-answer-content px-6 pb-5 text-xs text-slate-600 leading-relaxed border-t border-slate-50 pt-3">
              Yes, you can renew early! Florida law requires physician re-evaluation every 30 weeks (210 days) to prevent registry orders from expiring. We recommend scheduling your renewal appointment at least 2-3 weeks before your active order cycle expires.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script data-astro-rerun>
    // FAQ Accordion Toggle with Smooth Transitions
    const toggles = document.querySelectorAll('.faq-toggle');
    toggles.forEach(toggle => {
      toggle.addEventListener('click', () => {
        const id = toggle.getAttribute('data-faq');
        const answer = document.getElementById(id);
        const icon = toggle.querySelector('.faq-icon');
        const isOpen = answer.classList.contains('is-open');

        // Close all answers
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.remove('is-open'));
        document.querySelectorAll('.faq-icon').forEach(i => i.textContent = '＋');

        if (!isOpen) {
          answer.classList.add('is-open');
          icon.textContent = '－';
        }
      });
    });

    // Scroll Reveal Observer
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, {
      threshold: 0.1
    });

    document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
  </script>

